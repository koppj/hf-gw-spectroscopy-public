Cell[TextData[{
 "in the following, we carry out the steps from eq. 3.8 to eq. 3.10 in ",
 ButtonBox["arXiv:2406.03244",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/2406.03244"], None},
  ButtonNote->"https://arxiv.org/abs/2406.03244"],
 ", paying special attention to the angular factors."
}], "Text",
