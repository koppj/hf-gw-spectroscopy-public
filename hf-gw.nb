Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "summing", " ", "over", " ", "the", " ", "forward", " ", "and", " ", 
    "backward", " ", "trajectory", " ", "of", " ", "the", " ", "photon", " ", 
    "in", " ", "the", " ", "cavity", " ", "m", " ", "times"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{"n", ",", "m"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"$Assumptions", "=", 
     RowBox[{"Union", "[", 
      RowBox[{"$Assumptions", ",", 
       RowBox[{"{", 
        RowBox[{"m", ">", "0"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalDelta]\[Phi]2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[CapitalDelta]\[Phi]", "/.", 
            RowBox[{"\[Alpha]0", "->", 
             RowBox[{"\[Phi]", "+", 
              RowBox[{"2", " ", 
               RowBox[{"(", 
                RowBox[{"n", "-", "m"}], ")"}], " ", "\[Omega]g", " ", 
               "L"}]}]}]}], ")"}], "+", 
          RowBox[{"(", 
           RowBox[{"\[CapitalDelta]\[Phi]", "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"cos\[Theta]", "->", 
               RowBox[{"-", "cos\[Theta]"}]}], ",", 
              RowBox[{"\[Alpha]0", "->", 
               RowBox[{"\[Phi]", "+", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"2", "n"}], "+", "1", "-", "m"}], ")"}], 
                 "\[Omega]g", " ", "L"}], "-", 
                RowBox[{"\[Omega]g", " ", "L", " ", "cos\[Theta]"}]}]}]}], 
             "}"}]}], ")"}]}], ")"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "0", ",", "m"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"conversion", " ", "to", " ", 
     RowBox[{"\[Delta]\[Omega]", "/", "\[Omega]"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalDelta]\[Omega]1", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{"\[CapitalDelta]\[Phi]2", ",", "t"}], "]"}], "/", 
       "\[Omega]\[Gamma]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"t", "->", "L"}], ",", 
        RowBox[{"x", "->", "L"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"trig", "=", 
     RowBox[{"DeleteDuplicates", "@", 
