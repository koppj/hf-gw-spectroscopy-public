Cell[BoxData[{
 RowBox[{
  RowBox[{"A0", "=", 
   RowBox[{"Cos", "[", 
    RowBox[{"\[Omega]\[Gamma]", 
     RowBox[{"(", 
      RowBox[{"t", "-", "x"}], ")"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A1", "=", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"h", " ", "\[Omega]\[Gamma]"}], 
        RowBox[{"4", "\[Omega]g"}]], 
       RowBox[{"(", 
        RowBox[{"1", "+", "cos\[Theta]"}], ")"}], "\[Lambda]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Omega]\[Gamma]", "+", 
              RowBox[{"\[Lambda]", " ", "\[Omega]g"}]}], ")"}], 
            RowBox[{"(", 
             RowBox[{"t", "-", "x"}], ")"}]}], "+", 
           RowBox[{"\[Lambda]", " ", "\[Alpha]0"}]}], "]"}], "-", 
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Omega]\[Gamma]", "+", 
              RowBox[{"\[Lambda]", " ", "\[Omega]g"}]}], ")"}], "t"}], "-", 
           RowBox[{"\[Omega]\[Gamma]", " ", "x"}], "-", 
           RowBox[{"\[Lambda]", " ", "kx"}], "+", 
           RowBox[{"\[Lambda]", " ", "\[Alpha]0"}]}], "]"}]}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Lambda]", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", 
          RowBox[{"+", "1"}]}], "}"}]}], "}"}]}], "]"}], "/.", 
    RowBox[{"kx", "->", 
     RowBox[{"\[Omega]g", " ", "x", " ", "cos\[Theta]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalDelta]\[Phi]", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     FractionBox["1", "\[Omega]\[Gamma]"], 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{"A0", ",", "t"}], "]"}], "A1"}], "-", 
       RowBox[{"A0", " ", 
        RowBox[{"D", "[", 
         RowBox[{"A1", ",", "t"}], "]"}]}]}], 
      RowBox[{
       SuperscriptBox["A0", "2"], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox["\[Omega]\[Gamma]", "2"]], 
        SuperscriptBox[
         RowBox[{"D", "[", 
          RowBox[{"A0", ",", "t"}], "]"}], "2"]}]}]]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trig", "=", 
   RowBox[{"DeleteDuplicates", "@", 
    RowBox[{"Cases", "[", 
     RowBox[{"\[CapitalDelta]\[Phi]", ",", 
      RowBox[{"_Sin", "|", "_Cos", "|", "_Tan"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "Infinity"}], "}"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"repl", "=", 
   RowBox[{"Thread", "[", 
    RowBox[{"trig", "->", 
     RowBox[{"Array", "[", 
      RowBox[{"s", ",", 
       RowBox[{"Length", "[", "trig", "]"}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalDelta]\[Phi]0", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Normal", "[", 
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"\[CapitalDelta]\[Phi]", "/.", "repl"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Omega]g", ",", "0", ",", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}], "]"}], "/.", 
     RowBox[{"(", 
      RowBox[{"Reverse", "/@", "repl"}], ")"}]}], "]"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"alternative", " ", "approach"}], ",", " ", 
    RowBox[{"gives", " ", "the", " ", "same", " ", "result"}]}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A0", "=", 
   RowBox[{"Cos", "[", 
    RowBox[{"\[Omega]\[Gamma]t", "-", 
     RowBox[{"\[Omega]\[Gamma]", " ", "x"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A1", "=", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"h", " ", "\[Omega]\[Gamma]"}], 
        RowBox[{"4", "\[Omega]g"}]], 
